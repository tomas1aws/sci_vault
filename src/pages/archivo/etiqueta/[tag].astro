---
import Base from '../../../layouts/Base.astro'; import NodeList from '../../../components/NodeList.astro'; import { getVisibleNodes } from '../../../lib/content';
const all=await getVisibleNodes(); export function getStaticPaths(){return [...new Set(all.flatMap(n=>n.data.tags))].map(tag=>({params:{tag}}));}
const { tag }=Astro.params; const nodes=all.filter(n=>n.data.tags.includes(tag));
---
<Base title={`Etiqueta ${tag} · SciFi Vault`}><p class="kicker">Etiqueta</p><h1>#{tag}</h1><NodeList nodes={nodes}/></Base>
