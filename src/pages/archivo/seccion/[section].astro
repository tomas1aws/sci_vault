---
import Base from '../../../layouts/Base.astro';
import NodeList from '../../../components/NodeList.astro';
import { getNodesBySection } from '../../../lib/content';
import { sections, type SectionKey } from '../../../lib/taxonomy';

export async function getStaticPaths() {
  return Promise.all((Object.keys(sections) as SectionKey[]).map(async (section) => ({
    params: { section },
    props: { nodes: await getNodesBySection(section) },
  })));
}

const { section } = Astro.params;
const { nodes } = Astro.props;
const info = sections[section];
---
<Base title={`${info.title} · SciFi Vault`}><p class="kicker">Sección</p><h1>{info.title}</h1><p class="prose">{info.description}</p><NodeList nodes={nodes}/></Base>
