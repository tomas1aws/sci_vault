---
import Base from '../../../layouts/Base.astro';
import NodeList from '../../../components/NodeList.astro';
import { getVisibleNodes } from '../../../lib/content';
import { sections, sectionForType } from '../../../lib/taxonomy';

export async function getStaticPaths() {
  const all = await getVisibleNodes();

  return Object.keys(sections).map((section) => ({
    params: { section },
    props: { nodes: all.filter((node) => sectionForType(node.data.type) === section) },
  }));
}

const { section } = Astro.params;
const { nodes } = Astro.props;
const info = sections[section];
---
<Base title={`${info.title} · SciFi Vault`}><p class="kicker">Sección</p><h1>{info.title}</h1><p class="prose">{info.description}</p><NodeList nodes={nodes}/></Base>
