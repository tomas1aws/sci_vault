---
import Base from '../../layouts/Base.astro'; import Relations from '../../components/Relations.astro';
import { render } from 'astro:content';
import { explicitRelated, getVisibleNodes, suggestedRelated } from '../../lib/content';
import { archiveCode, sectionForType, typeLabels } from '../../lib/taxonomy';
export async function getStaticPaths(){ const all=await getVisibleNodes(); return all.map(node=>({params:{slug:node.data.slug},props:{node}})); }
const { node } = Astro.props; const all=await getVisibleNodes(); const { Content } = await render(node); const explicit=explicitRelated(node, all); const suggested=suggestedRelated(node, all);
---
<Base title={`${node.data.title} · SciFi Vault`} description={node.data.description}><nav class="crumbs"><a href="/archivo">Archivo</a> / <a href={`/archivo/seccion/${sectionForType(node.data.type)}`}>{sectionForType(node.data.type)}</a> / {node.data.title}</nav>{node.data.status==='draft' && <div class="draft">BORRADOR visible solo en desarrollo local</div>}<article class="node-layout"><div><p class="code">{archiveCode(node)}</p><h1>{node.data.title}</h1><p class="prose">{node.data.description}</p><div class="meta">{typeLabels[node.data.type]} · {sectionForType(node.data.type)}{node.data.year ? ` · ${node.data.year}` : ''}{node.data.spoilerLevel ? ` · spoilers: ${node.data.spoilerLevel}` : ''}</div><div class="tags">{node.data.tags.map((t:string)=><a class="tag" href={`/archivo/etiqueta/${t}`}>#{t}</a>)}</div><div class="prose"><Content /></div></div><aside class="side"><Relations explicit={explicit} suggested={suggested}/></aside></article></Base>
