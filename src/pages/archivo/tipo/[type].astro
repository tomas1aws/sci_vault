---
import Base from '../../../layouts/Base.astro'; import NodeList from '../../../components/NodeList.astro'; import { getVisibleNodes } from '../../../lib/content'; import { typeLabels } from '../../../lib/taxonomy';
const nodesAll=await getVisibleNodes(); export function getStaticPaths(){return Object.keys(typeLabels).map(type=>({params:{type}}));}
const { type }=Astro.params; const nodes=nodesAll.filter(n=>n.data.type===type);
---
<Base title={`${typeLabels[type]} · SciFi Vault`}><p class="kicker">Tipo</p><h1>{typeLabels[type]}</h1><NodeList nodes={nodes}/></Base>
